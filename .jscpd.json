{
  "threshold": 5,
  "reporters": ["console", "html", "json"],
  "ignore": [
    "**/node_modules/**",
    "**/.git/**",
    "**/kitty-specs.archived/**",
    "**/context/**",
    "**/.agent/**",
    "**/.codex/**",
    "**/.opencode/**",
    "**/.cavekit/**",
    "**/coverage/**",
    "**/dist/**",
    "**/build/**"
  ],
  "absolute": true,
  "gitignore": true,
  "minTokens": 50,
  "minLines": 10,
  "config": "ci"
}
