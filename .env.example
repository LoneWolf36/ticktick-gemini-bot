# ============================================================
# Required variables — the app will not start without these
# ============================================================

# TickTick OAuth credentials
# Create an app at https://developer.ticktick.com
TICKTICK_CLIENT_ID=your_ticktick_client_id
TICKTICK_CLIENT_SECRET=your_ticktick_client_secret
TICKTICK_REDIRECT_URI=http://127.0.0.1:8080

# TickTick access token — obtained automatically via OAuth flow.
# Run `node server.js`, visit http://127.0.0.1:8080, authorize TickTick,
# and the token will be printed to console. Copy it here for deployment.
# TICKTICK_ACCESS_TOKEN=auto_obtained_via_oauth
# TICKTICK_REFRESH_TOKEN=auto_obtained_via_oauth_refresh_token

# Telegram Bot
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Your Telegram chat ID (run /start on your bot to see it, then add it here)
# Required for security — only you can use the bot
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Gemini API key
# Get one free at https://aistudio.google.com/apikey
# Preferred: GEMINI_API_KEYS (comma-separated for key rotation) — the app validates this at startup
# Fallback: GEMINI_API_KEY (single key, legacy support — used only if GEMINI_API_KEYS is not set)
GEMINI_API_KEYS=key1,key2,key3
# GEMINI_API_KEY=your_gemini_api_key  # used only if GEMINI_API_KEYS is not set

# Gemini Models
GEMINI_MODEL_FAST=gemini-2.5-flash      # Fast model for intent extraction and simple tasks
GEMINI_MODEL_ADVANCED=gemini-2.5-pro    # Advanced model for weekly review and complex reasoning

# Gemini model fallback chains (comma-separated, tried in order when primary is rate-limited)
# Recommended: gemini-3-flash-preview,gemini-2.5-flash-lite,gemini-3.1-flash-lite-preview
GEMINI_MODEL_FAST_FALLBACKS=gemini-3-flash-preview,gemini-2.5-flash-lite,gemini-3.1-flash-lite-preview
# Recommended: gemini-2.5-flash (free fallback when pro is unavailable)
GEMINI_MODEL_ADVANCED_FALLBACKS=gemini-2.5-flash

# ============================================================
# Optional variables — sensible defaults provided
# ============================================================

# User config
USER_TIMEZONE=Europe/Dublin             # Your timezone (default: Europe/Dublin)
DAILY_BRIEFING_HOUR=8                   # Hour for morning briefing, 24h format (default: 8)
WEEKLY_DIGEST_DAY=0                     # Day for weekly digest, 0=Sunday (default: 0)
POLL_INTERVAL_MINUTES=5                 # How often to check for new tasks (default: 5)
BEHAVIORAL_SIGNAL_RETENTION_DAYS=30     # Active behavioral-signal window in days (default: 30)
BEHAVIORAL_SIGNAL_ARCHIVE_DAYS=90       # Total retained behavioral-signal history in days (default: 90)

# Default project for new tasks is exact-match only.
# If no exact configured destination exists, writes block instead of guessing Inbox/default.
# DEFAULT_PROJECT_NAME=

# Autonomous mode
AUTO_APPLY_LIFE_ADMIN=true              # Auto-apply life-admin tasks (default: true)
AUTO_APPLY_MODE=metadata-only           # metadata-only | full (default: metadata-only)
AUTO_APPLY_STRATEGIC_PRIORITY=true      # Auto-write P3 for strategic tasks with low priority (default: true)

# Diagnostics
# Keep false for normal use. When true in NODE_ENV=development, pipeline receipts may include
# developer diagnostics for local debugging. Production/user-facing receipts stay redacted.
DEBUG_RECEIPTS=false

# Bot mode and port
# 'polling' for local dev, 'webhook' for cloud deployment
BOT_MODE=polling
PORT=8080

# Webhook security (used only when BOT_MODE=webhook)
# TELEGRAM_WEBHOOK_SECRET=your_random_secret

# ----------------------------------------------------------
# Webhook mode (cloud deployment — uncomment when using)
# ----------------------------------------------------------
# BOT_MODE=webhook
# PORT=10000
# WEBHOOK_URL=https://your-app.onrender.com
# TELEGRAM_WEBHOOK_SECRET=your_random_secret_token_for_webhook_security

# ----------------------------------------------------------
# Optional infrastructure
# ----------------------------------------------------------

# Redis (optional — for persistent storage on cloud deployments)
# Without this, the bot uses local file storage (data/store.json)
# REDIS_URL=redis://default:password@host:port

# User context (optional in env — file-based user_context.js takes precedence locally)
# USER_CONTEXT=<paste content of services/user_context.js>

# Pipeline transient retry tuning (optional)
# PIPELINE_TRANSIENT_MAX_RETRIES=1
# PIPELINE_TRANSIENT_BASE_DELAY_MS=250
# PIPELINE_TRANSIENT_MAX_DELAY_MS=4000

# TickTick rate-limit retry tuning (optional)
# TICKTICK_RATE_LIMIT_MAX_RETRIES=3
# TICKTICK_RATE_LIMIT_BASE_DELAY_MS=1000
# TICKTICK_RATE_LIMIT_MAX_DELAY_MS=30000
