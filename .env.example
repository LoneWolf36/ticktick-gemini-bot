# TickTick OAuth credentials
# Create an app at https://developer.ticktick.com
TICKTICK_CLIENT_ID=your_ticktick_client_id
TICKTICK_CLIENT_SECRET=your_ticktick_client_secret
TICKTICK_REDIRECT_URI=http://127.0.0.1:8080

# For cloud deployment (Render/Railway):
# Run OAuth locally first, then copy the token printed in console
# TICKTICK_ACCESS_TOKEN=your_access_token

# Gemini API key
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Telegram Bot
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Your Telegram chat ID (run /start on your bot to see it, then add it here)
# Required for security — only you can use the bot
TELEGRAM_CHAT_ID=your_telegram_chat_id

# User config
USER_TIMEZONE=Europe/Dublin             # Your timezone
DAILY_BRIEFING_HOUR=8                   # Hour for morning briefing (24h)
WEEKLY_DIGEST_DAY=0                     # Day for weekly digest (0=Sunday)
POLL_INTERVAL_MINUTES=5                 # How often to check for new tasks

# Autonomous mode
AUTO_APPLY_LIFE_ADMIN=true              # Auto-apply life-admin tasks
AUTO_APPLY_DROPS=false                  # Auto-apply consider-dropping tasks
AUTO_APPLY_MODE=metadata-only           # metadata-only | full

# Bot mode: 'polling' for local dev, 'webhook' for cloud deployment
BOT_MODE=polling
PORT=8080

# Only needed for webhook mode (cloud deployment)
# BOT_MODE=webhook
# PORT=10000
# WEBHOOK_URL=https://your-app.onrender.com

# Redis (optional — for persistent storage on cloud deployments)
# Without this, the bot uses local file storage (data/store.json)
# REDIS_URL=redis://default:password@host:port
