{
    "name": "ticktick-gemini",
    "version": "2.0.0",
    "description": "AI accountability partner: TickTick + Gemini + Telegram",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "test": "npm run test:regression",
        "test:regression": "node --test --test-concurrency=1 tests/*.test.js",
        "check:duplicates": "./scripts/check-duplicates.sh",
        "check:test-sizes": "node scripts/check-test-sizes.mjs",
        "check:jscpd": "jscpd --threshold 5",
        "lint:duplicates": "jscpd",
        "lint:duplicates:fix": "jscpd --mode strict",
        "lint": "npm run check:duplicates",
        "docs:typedoc": "typedoc --entryPointStrategy expand ./services ./bot server.js --out docs/api",
        "docs:map": "jsdoc2md 'services/**/*.js' 'bot/**/*.js' server.js > context/refs/codebase-function-map.md"
    },
    "dependencies": {
        "@ax-llm/ax": "^19.0.13",
        "@google/genai": "^1.50.1",
        "ajv": "^8.18.0",
        "ajv-formats": "^3.0.1",
        "axios": "^1.7.0",
        "chalk": "^5.3.0",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "grammy": "^1.30.0",
        "ioredis": "^5.9.3",
        "node-cron": "^3.0.3"
    },
    "devDependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@types/node": "^25.6.0",
        "@types/node-fetch": "^2.6.13",
        "jscpd": "^4.0.8",
        "jsdoc-to-markdown": "^9.1.3",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3"
    }
}
