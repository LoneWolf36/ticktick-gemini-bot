{
    "name": "ticktick-gemini",
    "version": "2.0.0",
    "description": "AI accountability partner: TickTick + Gemini + Telegram",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "checkpoint": "node commands/save-checkpoint.js",
        "check:duplicates": "./scripts/check-duplicates.sh",
        "check:jscpd": "jscpd --threshold 5",
        "lint:duplicates": "jscpd",
        "lint:duplicates:fix": "jscpd --mode strict",
        "lint": "npm run check:duplicates"
    },
    "dependencies": {
        "@ax-llm/ax": "^19.0.13",
        "@google/generative-ai": "^0.21.0",
        "ajv": "^8.18.0",
        "ajv-formats": "^3.0.1",
        "axios": "^1.7.0",
        "chalk": "^5.3.0",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "grammy": "^1.30.0",
        "ioredis": "^5.9.3",
        "node-cron": "^3.0.3"
    },
    "devDependencies": {
        "jscpd": "^4.0.8"
    }
}
