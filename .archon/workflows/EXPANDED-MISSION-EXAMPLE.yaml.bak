# ═══════════════════════════════════════════════════════════════════
# EXPANDED MISSION EXAMPLE — How to use the Universal Template
# ═══════════════════════════════════════════════════════════════════
#
# This file demonstrates how to expand the spec-kitty-universal.yaml
# template for a concrete mission. It shows a fully expanded Mission 001
# with 3 WPs, ready to be merged into a project-specific workflow.
#
# To use: Copy the nodes below into your workflow YAML, replacing
# the template placeholders with concrete values.
#
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────
# MISSION 001: Task Operations Pipeline (fully expanded example)
# ─────────────────────────────────────────────────────────────────────

nodes:
  # ─── WP01: AX Intent Extraction ─────────────────────────────
  - id: m001-wp01-implement
    command: spec-kitty-implement
    args:
      mission: "001-task-operations-pipeline"
      workPackage: "WP01"
    context: fresh

  - id: m001-wp01-validate
    command: spec-kitty-validate
    depends_on: [m001-wp01-implement]
    context: fresh

  - id: m001-wp01-validate-fallback
    command: spec-kitty-implement
    args:
      mission: "001-task-operations-pipeline"
      workPackage: "WP01"
      retry: true
    depends_on: [m001-wp01-validate]
    trigger_rule: on_failure
    context: fresh

  - id: m001-wp01-revalidate
    command: spec-kitty-validate
    depends_on: [m001-wp01-validate-fallback]
    context: fresh

  - id: m001-wp01-move-task
    command: shell
    args:
      script: |
        spec-kitty move-task --mission 001-task-operations-pipeline WP01 --to done
    depends_on: [m001-wp01-validate]
    context: fresh

  # ─── WP02: Normalizer Core (depends on WP01) ────────────────
  - id: m001-wp02-implement
    command: spec-kitty-implement
    args:
      mission: "001-task-operations-pipeline"
      workPackage: "WP02"
    depends_on: [m001-wp01-validate]
    context: fresh

  - id: m001-wp02-validate
    command: spec-kitty-validate
    depends_on: [m001-wp02-implement]
    context: fresh

  - id: m001-wp02-move-task
    command: shell
    args:
      script: |
        spec-kitty move-task --mission 001-task-operations-pipeline WP02 --to done
    depends_on: [m001-wp02-validate]
    context: fresh

  # ─── WP03: TickTick Adapter (depends on WP01, WP02) ─────────
  - id: m001-wp03-implement
    command: spec-kitty-implement
    args:
      mission: "001-task-operations-pipeline"
      workPackage: "WP03"
    depends_on: [m001-wp02-validate]
    context: fresh

  - id: m001-wp03-validate
    command: spec-kitty-validate
    depends_on: [m001-wp03-implement]
    context: fresh

  - id: m001-wp03-move-task
    command: shell
    args:
      script: |
        spec-kitty move-task --mission 001-task-operations-pipeline WP03 --to done
    depends_on: [m001-wp03-validate]
    context: fresh

  # Last WP validate — anchor for review gate
  - id: m001-wp-last-validate
    command: spec-kitty-validate
    depends_on: [m001-wp03-validate]
    context: fresh

  # ═══════════════════════════════════════════════════════════════
  # REVIEW GATE — 5 parallel agents
  # ═══════════════════════════════════════════════════════════════

  - id: m001-review-architecture
    command: spec-kitty-review-architecture
    args:
      mission: "001-task-operations-pipeline"
    depends_on: [m001-wp-last-validate]
    context: fresh
    timeout: 600

  - id: m001-review-security
    command: spec-kitty-review-security
    args:
      mission: "001-task-operations-pipeline"
    depends_on: [m001-wp-last-validate]
    context: fresh
    timeout: 600

  - id: m001-review-testing
    command: spec-kitty-review-testing
    args:
      mission: "001-task-operations-pipeline"
    depends_on: [m001-wp-last-validate]
    context: fresh
    timeout: 600

  - id: m001-review-code-quality
    command: spec-kitty-review-code-quality
    args:
      mission: "001-task-operations-pipeline"
    depends_on: [m001-wp-last-validate]
    context: fresh
    timeout: 600

  - id: m001-review-product-vision
    command: spec-kitty-review-product-vision
    args:
      mission: "001-task-operations-pipeline"
      productVisionFile: "Product Vision and Behavioural Scope.md"
    depends_on: [m001-wp-last-validate]
    context: fresh
    timeout: 600

  # Synthesis — waits for ALL 5 reviews (all_done)
  - id: m001-synthesize-review
    command: spec-kitty-synthesize-review
    args:
      mission: "001-task-operations-pipeline"
      expectedReviews:
        - architecture
        - security
        - testing
        - code-quality
        - product-vision
    depends_on:
      [m001-review-architecture, m001-review-security, m001-review-testing, m001-review-code-quality, m001-review-product-vision]
    trigger_rule: all_done
    context: fresh

  # ─── Review-Fix Cycle 1 ─────────────────────────────────────
  - id: m001-fixes-cycle-1
    command: spec-kitty-implement-review-fixes
    args:
      mission: "001-task-operations-pipeline"
      cycle: 1
    depends_on: [m001-synthesize-review]
    context: fresh

  - id: m001-validation-cycle-1
    command: spec-kitty-validate-full
    depends_on: [m001-fixes-cycle-1]
    context: fresh

  # Full re-review (all 5 agents)
  - id: m001-rereview-arch-cycle-1
    command: spec-kitty-review-architecture
    args:
      mission: "001-task-operations-pipeline"
      cycle: 1
    depends_on: [m001-validation-cycle-1]
    context: fresh
    timeout: 600

  - id: m001-rereview-sec-cycle-1
    command: spec-kitty-review-security
    args:
      mission: "001-task-operations-pipeline"
      cycle: 1
    depends_on: [m001-validation-cycle-1]
    context: fresh
    timeout: 600

  - id: m001-rereview-test-cycle-1
    command: spec-kitty-review-testing
    args:
      mission: "001-task-operations-pipeline"
      cycle: 1
    depends_on: [m001-validation-cycle-1]
    context: fresh
    timeout: 600

  - id: m001-rereview-quality-cycle-1
    command: spec-kitty-review-code-quality
    args:
      mission: "001-task-operations-pipeline"
      cycle: 1
    depends_on: [m001-validation-cycle-1]
    context: fresh
    timeout: 600

  - id: m001-rereview-vision-cycle-1
    command: spec-kitty-review-product-vision
    args:
      mission: "001-task-operations-pipeline"
      cycle: 1
    depends_on: [m001-validation-cycle-1]
    context: fresh
    timeout: 600

  - id: m001-rereview-synthesize-cycle-1
    command: spec-kitty-synthesize-review
    args:
      mission: "001-task-operations-pipeline"
      cycle: 1
    depends_on:
      [m001-rereview-arch-cycle-1, m001-rereview-sec-cycle-1, m001-rereview-test-cycle-1, m001-rereview-quality-cycle-1, m001-rereview-vision-cycle-1]
    trigger_rule: all_done
    context: fresh

  # ─── Review-Fix Cycle 2 ─────────────────────────────────────
  - id: m001-fixes-cycle-2
    command: spec-kitty-implement-review-fixes
    args:
      mission: "001-task-operations-pipeline"
      cycle: 2
    depends_on: [m001-rereview-synthesize-cycle-1]
    context: fresh

  - id: m001-validation-cycle-2
    command: spec-kitty-validate-full
    depends_on: [m001-fixes-cycle-2]
    context: fresh

  # Full re-review (all 5 agents)
  - id: m001-rereview-arch-cycle-2
    command: spec-kitty-review-architecture
    args:
      mission: "001-task-operations-pipeline"
      cycle: 2
    depends_on: [m001-validation-cycle-2]
    context: fresh
    timeout: 600

  - id: m001-rereview-sec-cycle-2
    command: spec-kitty-review-security
    args:
      mission: "001-task-operations-pipeline"
      cycle: 2
    depends_on: [m001-validation-cycle-2]
    context: fresh
    timeout: 600

  - id: m001-rereview-test-cycle-2
    command: spec-kitty-review-testing
    args:
      mission: "001-task-operations-pipeline"
      cycle: 2
    depends_on: [m001-validation-cycle-2]
    context: fresh
    timeout: 600

  - id: m001-rereview-quality-cycle-2
    command: spec-kitty-review-code-quality
    args:
      mission: "001-task-operations-pipeline"
      cycle: 2
    depends_on: [m001-validation-cycle-2]
    context: fresh
    timeout: 600

  - id: m001-rereview-vision-cycle-2
    command: spec-kitty-review-product-vision
    args:
      mission: "001-task-operations-pipeline"
      cycle: 2
    depends_on: [m001-validation-cycle-2]
    context: fresh
    timeout: 600

  - id: m001-rereview-synthesize-cycle-2
    command: spec-kitty-synthesize-review
    args:
      mission: "001-task-operations-pipeline"
      cycle: 2
    depends_on:
      [m001-rereview-arch-cycle-2, m001-rereview-sec-cycle-2, m001-rereview-test-cycle-2, m001-rereview-quality-cycle-2, m001-rereview-vision-cycle-2]
    trigger_rule: all_done
    context: fresh

  # ─── Review-Fix Cycle 3 (Final) ─────────────────────────────
  - id: m001-fixes-cycle-3
    command: spec-kitty-implement-review-fixes
    args:
      mission: "001-task-operations-pipeline"
      cycle: 3
    depends_on: [m001-rereview-synthesize-cycle-2]
    context: fresh

  - id: m001-validation-cycle-3
    command: spec-kitty-validate-full
    depends_on: [m001-fixes-cycle-3]
    context: fresh

  # Full re-review (all 5 agents)
  - id: m001-rereview-arch-cycle-3
    command: spec-kitty-review-architecture
    args:
      mission: "001-task-operations-pipeline"
      cycle: 3
    depends_on: [m001-validation-cycle-3]
    context: fresh
    timeout: 600

  - id: m001-rereview-sec-cycle-3
    command: spec-kitty-review-security
    args:
      mission: "001-task-operations-pipeline"
      cycle: 3
    depends_on: [m001-validation-cycle-3]
    context: fresh
    timeout: 600

  - id: m001-rereview-test-cycle-3
    command: spec-kitty-review-testing
    args:
      mission: "001-task-operations-pipeline"
      cycle: 3
    depends_on: [m001-validation-cycle-3]
    context: fresh
    timeout: 600

  - id: m001-rereview-quality-cycle-3
    command: spec-kitty-review-code-quality
    args:
      mission: "001-task-operations-pipeline"
      cycle: 3
    depends_on: [m001-validation-cycle-3]
    context: fresh
    timeout: 600

  - id: m001-rereview-vision-cycle-3
    command: spec-kitty-review-product-vision
    args:
      mission: "001-task-operations-pipeline"
      cycle: 3
    depends_on: [m001-validation-cycle-3]
    context: fresh
    timeout: 600

  - id: m001-rereview-synthesize-cycle-3
    command: spec-kitty-synthesize-review
    args:
      mission: "001-task-operations-pipeline"
      cycle: 3
    depends_on:
      [m001-rereview-arch-cycle-3, m001-rereview-sec-cycle-3, m001-rereview-test-cycle-3, m001-rereview-quality-cycle-3, m001-rereview-vision-cycle-3]
    trigger_rule: all_done
    context: fresh

  # ─── Systematic Debugger Escalation ─────────────────────────
  - id: m001-debugger-retry-1
    command: shell
    args:
      script: |
        echo "═══════════════════════════════════════════════════════"
        echo "SYSTEMATIC DEBUGGER — Mission 001-task-operations-pipeline, Retry 1/5"
        echo "═══════════════════════════════════════════════════════"
        echo "3 review-fix cycles exhausted. Analyzing root cause..."
    depends_on: [m001-rereview-synthesize-cycle-3]
    context: fresh

  - id: m001-debugger-fix-1
    command: spec-kitty-implement-review-fixes
    args:
      mission: "001-task-operations-pipeline"
      mode: debugger-assisted
      debuggerRetry: 1
    depends_on: [m001-debugger-retry-1]
    context: fresh

  - id: m001-debugger-validation-1
    command: spec-kitty-validate-full
    depends_on: [m001-debugger-fix-1]
    context: fresh

  # Full re-review after debugger fix (all 5 agents)
  - id: m001-debugger-rereview-arch-1
    command: spec-kitty-review-architecture
    args:
      mission: "001-task-operations-pipeline"
      debuggerRetry: 1
    depends_on: [m001-debugger-validation-1]
    context: fresh
    timeout: 600

  - id: m001-debugger-rereview-sec-1
    command: spec-kitty-review-security
    args:
      mission: "001-task-operations-pipeline"
      debuggerRetry: 1
    depends_on: [m001-debugger-validation-1]
    context: fresh
    timeout: 600

  - id: m001-debugger-rereview-test-1
    command: spec-kitty-review-testing
    args:
      mission: "001-task-operations-pipeline"
      debuggerRetry: 1
    depends_on: [m001-debugger-validation-1]
    context: fresh
    timeout: 600

  - id: m001-debugger-rereview-quality-1
    command: spec-kitty-review-code-quality
    args:
      mission: "001-task-operations-pipeline"
      debuggerRetry: 1
    depends_on: [m001-debugger-validation-1]
    context: fresh
    timeout: 600

  - id: m001-debugger-rereview-vision-1
    command: spec-kitty-review-product-vision
    args:
      mission: "001-task-operations-pipeline"
      debuggerRetry: 1
    depends_on: [m001-debugger-validation-1]
    context: fresh
    timeout: 600

  - id: m001-debugger-synthesize-1
    command: spec-kitty-synthesize-review
    args:
      mission: "001-task-operations-pipeline"
      debuggerRetry: 1
    depends_on:
      [m001-debugger-rereview-arch-1, m001-debugger-rereview-sec-1, m001-debugger-rereview-test-1, m001-debugger-rereview-quality-1, m001-debugger-rereview-vision-1]
    trigger_rule: all_done
    context: fresh

  # Checkpoint (links to cycle 1 synthesis as the pass path)
  - id: m001-checkpoint
    command: spec-kitty-checkpoint-save
    args:
      mission: "001-task-operations-pipeline"
      checkpointDir: ".archon/checkpoints"
      snapshotBefore: true
    depends_on: [m001-rereview-synthesize-cycle-1]
    context: fresh
