# ${config.resilience.checkpoint.directory}         — Checkpoint directory
# ${config.resilience.checkpoint.snapshotBeforeFix} — Snapshot before fix
# ${config.resilience.checkpoint.maxFixAttempts}    — Max fix attempts
# ${config.resilience.checkpoint.retentionDays}     — Checkpoint retention
# ${config.resilience.rollback.strategy}            — Rollback strategy
# ${config.resilience.rollback.autoRollbackOnFailure} — Auto rollback
