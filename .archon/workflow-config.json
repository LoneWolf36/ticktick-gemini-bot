  "review": {
    "agents": [
      {
        "id": "state-integrity-scanner",
        "skill": "spec-kitty-runtime-next",
        "weight": 0.2,
        "mandatory": true,
        "tags": [
          "spec-kitty",
          "state",
          "jsonl"
        ],
        "backup": false,
        "fallback": "code-reviewer"
      },
      {
        "id": "artifact-auditor",
        "skill": "spec-to-code-compliance",
        "weight": 0.15,
        "mandatory": false,
        "tags": [
          "spec",
          "plan",
          "tasks",
          "evidence"
        ],
        "backup": false,
        "fallback": "code-reviewer"
      },
      {
        "id": "risk-classifier",
        "skill": "agent-orchestration-multi-agent-optimize",
        "weight": 0.15,
        "mandatory": true,
        "tags": [
          "risk",
          "routing",
          "model-selection"
        ],
        "backup": false,
        "fallback": "architect-review"
      },
      {
        "id": "product-vision-gate",
        "skill": "product-manager",
        "weight": 0.2,
        "mandatory": true,
        "tags": [
          "product",
          "vision",
          "scope"
        ],
        "backup": false,
        "fallback": "architect-review"
      },
      {
        "id": "review-gate",
        "skill": "code-reviewer",
        "weight": 0.2,
        "mandatory": true,
        "tags": [
          "review",
          "quality",
          "tests"
        ],
        "backup": false,
        "fallback": "architect-review"
      },
      {
        "id": "architect-review",
        "skill": "architect-review",
        "weight": 0.1,
        "mandatory": false,
        "tags": [
          "architecture",
          "design"
        ],
        "backup": true
      },
      {
        "id": "code-reviewer",
        "skill": "code-reviewer",
        "weight": 0.1,
        "mandatory": false,
        "tags": [
          "code-quality",
          "testing"
        ],
        "backup": true
      }
    ],
    "quorum": {
      "minimumPassing": 4,
      "mandatoryMustPass": true,
      "weightedThreshold": 0.7,
      "useWeighted": false
    },
    "timeout": 600,
    "parallelLimit": 4
  },
  "resilience": {
    "retry": {
      "maxAttempts": 2,
      "backoffMultiplier": 2,
      "initialDelaySeconds": 10,
      "maxDelaySeconds": 120
    },
    "circuitBreaker": {
      "failureThreshold": 2,
      "escalationChannel": "human",
      "escalationConfig": {
        "message": "Spec Kitty quality gate blocked {mission}/{wp}. Review state integrity and reconciliation artifacts.",
        "pauseTimeoutMinutes": 60
      },
      "autoResumeWithReducedQuorum": false
    },
    "checkpoint": {
      "enabled": true,
      "directory": ".archon/checkpoints",
      "snapshotBeforeFix": true,
      "maxFixAttempts": 1,
      "retentionDays": 30
    },
    "rollback": {
      "strategy": "git-stash",
      "autoRollbackOnFailure": false
    }
  },
  "ai": {
    "provider": "codex",
    "model": "gpt-5.4-mini",
    "highRiskModel": "gpt-5.4",
    "temperature": 0.2,
    "maxTokens": 8192
  },
  "notifications": {
    "onCheckpoint": false,
    "onReviewPass": false,
    "onReviewFail": true,
    "onCircuitBreakerTrip": true,
    "onPhaseComplete": true,
    "onMissionComplete": false
  }
}
