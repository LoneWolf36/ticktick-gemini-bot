      "node tests/run-regression-tests.mjs"
    ],
    "commitTemplate": {
      "conventionalCommits": true,
      "coAuthors": [
        "Codex GPT-5 <noreply@openai.com>"
      ],
      "scopePattern": "^(feat|fix|docs|chore|test|ref)\\((.+)\\):"
