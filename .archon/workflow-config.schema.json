{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/archon-workflow-config.schema.json",
  "title": "Archon Spec-Kitty Workflow Configuration",
  "description": "Parameterized configuration for running spec-kitty missions across any project. Copy workflow-config.example.json and adapt for your project.",
  "type": "object",
  "required": ["project", "missions", "review", "resilience"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["root", "specDirectory"],
      "properties": {
        "root": {
          "type": "string",
          "description": "Absolute or relative path to the project root directory.",
          "examples": [".", "/home/user/my-project"]
        },
        "specDirectory": {
          "type": "string",
          "description": "Directory containing mission specs (spec.md, plan.md, tasks/). Relative to project root.",
          "default": "kitty-specs",
          "examples": ["kitty-specs", "specs", "docs/missions"]
        },
        "baseBranch": {
          "type": "string",
          "description": "Git base branch for worktrees and PRs.",
          "default": "master",
          "examples": ["master", "main", "develop"]
        },
        "validationCommands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Shell commands to validate the project after each WP implementation. Each command exits 0 on success.",
          "default": ["npm test"],
          "examples": [
            ["npm test", "npm run lint"],
            ["pytest tests/", "mypy src/"],
            ["go test ./...", "golangci-lint run"]
          ]
        },
        "commitTemplate": {
          "type": "object",
          "description": "Git commit conventions for the project.",
          "properties": {
            "conventionalCommits": { "type": "boolean", "default": true },
            "coAuthors": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Co-authored-by trailers to append to commit messages.",
              "examples": [["Codex GPT-5 <noreply@openai.com>"]]
            },
            "scopePattern": {
              "type": "string",
              "description": "Regex pattern for commit scope extraction from WP or mission.",
              "default": "^feat\\((.+)\\):"
            }
          }
        },
        "environment": {
          "type": "object",
          "description": "Environment variables to inject into workflow nodes.",
          "additionalProperties": { "type": "string" },
          "examples": [{ "NODE_ENV": "test", "CI": "true" }]
        }
      }
    },
    "missions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "slug"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Mission identifier (e.g., '001', 'feature-auth').",
            "examples": ["001", "feature-auth", "payment-integration"]
          },
          "slug": {
            "type": "string",
            "description": "Directory slug for the mission under specDirectory.",
            "examples": ["001-task-operations-pipeline", "feature-auth"]
          },
          "workPackages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "file"],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Work package ID (e.g., 'WP01').",
                  "examples": ["WP01", "WP02"]
                },
                "file": {
                  "type": "string",
                  "description": "Path to the WP markdown file, relative to mission spec directory.",
                  "examples": ["tasks/WP01-ax-intent-extraction.md"]
                },
                "dependencies": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "WP IDs that must complete before this WP starts.",
                  "examples": [["WP01", "WP02"]]
                },
                "skipIfComplete": {
                  "type": "boolean",
                  "default": true,
                  "description": "Skip this WP if status.events.jsonl shows it is already done."
                }
              }
            }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "required": ["agents", "quorum"],
      "properties": {
        "agents": {
          "type": "array",
          "minItems": 3,
          "maxItems": 10,
          "description": "Review agents available for assignment. The system selects the best 5 per feature based on spec content analysis.",
          "items": {
            "type": "object",
            "required": ["id", "skill", "weight"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique agent identifier.",
                "examples": ["security-auditor", "ai-engineer", "architect-review"]
              },
              "skill": {
                "type": "string",
                "description": "The Qwen skill name to invoke for this reviewer.",
                "examples": ["security-auditor", "ai-engineer", "architect-review", "api-design-principles"]
              },
              "weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Voting weight for quorum calculation. Mandatory agents have higher weight.",
                "default": 0.2
              },
              "mandatory": {
                "type": "boolean",
                "default": false,
                "description": "If true, this agent's approval is required regardless of quorum. Typically security + architecture."
              },
              "tags": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Domain tags for dynamic selection. Used to match spec content keywords to agent expertise.",
                "examples": [["security", "auth", "oauth"], ["ai", "llm", "ml", "prompt"], ["api", "rest", "graphql"]]
              },
              "backup": {
                "type": "boolean",
                "default": false,
                "description": "If true, this agent is in the backup pool for substitution when primary agents fail."
              },
              "fallback": {
                "type": "string",
                "description": "Agent ID to substitute if this agent fails. Creates a chain of fallback candidates.",
                "examples": ["code-reviewer", "senior-architect"]
              }
            }
          }
        },
        "quorum": {
          "type": "object",
          "required": ["minimumPassing", "mandatoryMustPass"],
          "properties": {
            "minimumPassing": {
              "type": "integer",
              "minimum": 2,
              "maximum": 10,
              "default": 3,
              "description": "Minimum number of agents (out of assigned reviewers) that must pass for the review to succeed."
            },
            "mandatoryMustPass": {
              "type": "boolean",
              "default": true,
              "description": "If true, all mandatory agents must pass regardless of minimumPassing count."
            },
            "weightedThreshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.6,
              "description": "Alternative to minimumPassing: sum of passing agent weights must exceed this threshold."
            },
            "useWeighted": {
              "type": "boolean",
              "default": false,
              "description": "If true, use weightedThreshold instead of minimumPassing for quorum determination."
            }
          }
        },
        "timeout": {
          "type": "integer",
          "minimum": 60,
          "default": 600,
          "description": "Maximum seconds allowed per review agent before it is considered failed."
        },
        "parallelLimit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 5,
          "description": "Maximum number of review agents to run in parallel per feature."
        }
      }
    },
    "resilience": {
      "type": "object",
      "required": ["retry", "circuitBreaker", "checkpoint"],
      "properties": {
        "retry": {
          "type": "object",
          "properties": {
            "maxAttempts": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 3,
              "description": "Maximum retry attempts per review agent before substitution or escalation."
            },
            "backoffMultiplier": {
              "type": "number",
              "minimum": 1,
              "default": 2,
              "description": "Exponential backoff multiplier between retry attempts."
            },
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 5,
              "default": 10,
              "description": "Initial delay in seconds before the first retry attempt."
            },
            "maxDelaySeconds": {
              "type": "integer",
              "minimum": 30,
              "default": 120,
              "description": "Maximum delay in seconds between retry attempts (cap)."
            }
          }
        },
        "circuitBreaker": {
          "type": "object",
          "properties": {
            "failureThreshold": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 4,
              "description": "Number of failed agents (out of parallelLimit) before tripping the circuit breaker and pausing the phase."
            },
            "escalationChannel": {
              "type": "string",
              "enum": ["human", "slack", "email", "webhook", "none"],
              "default": "human",
              "description": "How to escalate when the circuit breaker trips."
            },
            "escalationConfig": {
              "type": "object",
              "description": "Configuration for the escalation channel.",
              "properties": {
                "webhookUrl": {
                  "type": "string",
                  "description": "URL for webhook escalation notification.",
                  "format": "uri"
                },
                "message": {
                  "type": "string",
                  "default": "Circuit breaker tripped for {mission}/{wp}. {failedCount}/{totalCount} review agents failed after {retryCount} retries. Manual intervention required.",
                  "description": "Template for escalation message. Supports {mission}, {wp}, {failedCount}, {totalCount}, {retryCount}."
                },
                "pauseTimeoutMinutes": {
                  "type": "integer",
                  "minimum": 5,
                  "default": 60,
                  "description": "Maximum minutes to pause and wait for human intervention before auto-resuming with reduced quorum."
                }
              }
            },
            "autoResumeWithReducedQuorum": {
              "type": "boolean",
              "default": false,
              "description": "If true, after pauseTimeoutMinutes, resume with minimumPassing - 1 (minimum 2)."
            }
          }
        },
        "checkpoint": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable checkpoint/resume between phases."
            },
            "directory": {
              "type": "string",
              "default": ".archon/checkpoints",
              "description": "Directory to store checkpoint files. Relative to project root."
            },
            "snapshotBeforeFix": {
              "type": "boolean",
              "default": true,
              "description": "Create a git stash or worktree snapshot before attempting review fixes."
            },
            "maxFixAttempts": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5,
              "default": 3,
              "description": "Maximum fix attempts per review finding before escalating to human."
            },
            "retentionDays": {
              "type": "integer",
              "minimum": 1,
              "default": 30,
              "description": "Days to retain checkpoint files before automatic cleanup."
            }
          }
        },
        "rollback": {
          "type": "object",
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["git-stash", "git-reset", "worktree-snapshot"],
              "default": "git-stash",
              "description": "Strategy for creating pre-fix snapshots."
            },
            "autoRollbackOnFailure": {
              "type": "boolean",
              "default": false,
              "description": "Automatically rollback if fix attempts exhaust without success."
            }
          }
        }
      }
    },
    "ai": {
      "type": "object",
      "description": "AI provider and model configuration for review agents.",
      "properties": {
        "provider": {
          "type": "string",
          "default": "qwen",
          "examples": ["qwen", "openai", "anthropic", "gemini"]
        },
        "model": {
          "type": "string",
          "default": "coder-model",
          "examples": ["coder-model", "claude-sonnet-4", "gpt-5"]
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "default": 0.2,
          "description": "Temperature for review agent prompts (lower = more deterministic review)."
        },
        "maxTokens": {
          "type": "integer",
          "default": 8192,
          "description": "Maximum tokens per review agent response."
        }
      }
    },
    "notifications": {
      "type": "object",
      "description": "Notification configuration for workflow events.",
      "properties": {
        "onCheckpoint": { "type": "boolean", "default": false },
        "onReviewPass": { "type": "boolean", "default": false },
        "onReviewFail": { "type": "boolean", "default": true },
        "onCircuitBreakerTrip": { "type": "boolean", "default": true },
        "onPhaseComplete": { "type": "boolean", "default": true },
        "onMissionComplete": { "type": "boolean", "default": true },
        "channels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["webhook", "slack", "email", "telegram"] },
              "url": { "type": "string", "format": "uri" },
              "events": {
                "type": "array",
                "items": { "type": "string" },
                "examples": [["circuit_breaker", "mission_complete"]]
              }
            }
          }
        }
      }
    }
  }
}
