{
  "_comment": "Archon Spec-Kitty Workflow Configuration — Example for ANY project",
  "_usage": "Copy this file to .archon/workflow-config.json and adapt values for your project.",
  "_schema": "Validate against .archon/workflow-config.schema.json",

  "project": {
    "root": ".",
    "specDirectory": "kitty-specs",
    "baseBranch": "master",
    "validationCommands": [
      "npm test",
      "node tests/run-regression-tests.mjs"
    ],
    "commitTemplate": {
      "conventionalCommits": true,
      "coAuthors": [
        "Codex GPT-5 <noreply@openai.com>"
      ],
      "scopePattern": "^feat\\((.+)\\):"
    },
    "environment": {
      "NODE_ENV": "test",
      "CI": "true"
    }
  },

  "missions": [
    {
      "id": "001",
      "slug": "001-task-operations-pipeline",
      "workPackages": [
        {
          "id": "WP01",
          "file": "tasks/WP01-ax-intent-extraction.md",
          "dependencies": [],
          "skipIfComplete": true
        },
        {
          "id": "WP02",
          "file": "tasks/WP02-normalizer-core.md",
          "dependencies": ["WP01"],
          "skipIfComplete": true
        },
        {
          "id": "WP03",
          "file": "tasks/WP03-ticktick-adapter.md",
          "dependencies": ["WP01", "WP02"],
          "skipIfComplete": true
        }
      ]
    },
    {
      "id": "002",
      "slug": "002-natural-language-task-mutations",
      "workPackages": [
        {
          "id": "WP02",
          "file": "tasks/WP02-ax-mutation-intent.md",
          "dependencies": [],
          "skipIfComplete": true
        }
      ]
    }
  ],

  "review": {
    "agents": [
      {
        "id": "architect-review",
        "skill": "architect-review",
        "weight": 0.25,
        "mandatory": true,
        "tags": ["architecture", "design-patterns", "scalability", "ddd"],
        "backup": false,
        "fallback": "senior-architect"
      },
      {
        "id": "security-auditor",
        "skill": "security-auditor",
        "weight": 0.25,
        "mandatory": true,
        "tags": ["security", "auth", "owasp", "vulnerability", "injection"],
        "backup": false,
        "fallback": "backend-security-coder"
      },
      {
        "id": "ai-engineer",
        "skill": "ai-engineer",
        "weight": 0.15,
        "mandatory": false,
        "tags": ["ai", "llm", "ml", "prompt", "embedding", "rag", "agent"],
        "backup": false,
        "fallback": "llm-ops"
      },
      {
        "id": "backend-dev-guidelines",
        "skill": "backend-dev-guidelines",
        "weight": 0.15,
        "mandatory": false,
        "tags": ["api", "rest", "graphql", "backend", "database", "service"],
        "backup": false,
        "fallback": "nodejs-backend-patterns"
      },
      {
        "id": "code-reviewer",
        "skill": "code-reviewer",
        "weight": 0.1,
        "mandatory": false,
        "tags": ["code-quality", "testing", "clean-code", "refactor"],
        "backup": false,
        "fallback": "uncle-bob-craft"
      },
      {
        "id": "frontend-developer",
        "skill": "frontend-developer",
        "weight": 0.1,
        "mandatory": false,
        "tags": ["frontend", "react", "ui", "component", "css"],
        "backup": false,
        "fallback": "senior-frontend"
      },

      {
        "id": "senior-architect",
        "skill": "senior-architect",
        "weight": 0.2,
        "mandatory": false,
        "tags": ["architecture", "design", "system-design"],
        "backup": true
      },
      {
        "id": "backend-security-coder",
        "skill": "backend-security-coder",
        "weight": 0.2,
        "mandatory": false,
        "tags": ["security", "backend", "input-validation"],
        "backup": true
      },
      {
        "id": "llm-ops",
        "skill": "llm-ops",
        "weight": 0.15,
        "mandatory": false,
        "tags": ["llm", "rag", "embedding", "vector", "cost"],
        "backup": true
      },
      {
        "id": "nodejs-backend-patterns",
        "skill": "nodejs-backend-patterns",
        "weight": 0.15,
        "mandatory": false,
        "tags": ["nodejs", "backend", "api", "express"],
        "backup": true
      },
      {
        "id": "uncle-bob-craft",
        "skill": "uncle-bob-craft",
        "weight": 0.1,
        "mandatory": false,
        "tags": ["clean-code", "solid", "craftsmanship"],
        "backup": true
      },
      {
        "id": "senior-frontend",
        "skill": "senior-frontend",
        "weight": 0.1,
        "mandatory": false,
        "tags": ["frontend", "react", "nextjs", "tailwind"],
        "backup": true
      }
    ],

    "quorum": {
      "minimumPassing": 3,
      "mandatoryMustPass": true,
      "weightedThreshold": 0.6,
      "useWeighted": false
    },

    "timeout": 600,
    "parallelLimit": 5
  },

  "resilience": {
    "retry": {
      "maxAttempts": 3,
      "backoffMultiplier": 2,
      "initialDelaySeconds": 10,
      "maxDelaySeconds": 120
    },

    "circuitBreaker": {
      "failureThreshold": 4,
      "escalationChannel": "human",
      "escalationConfig": {
        "message": "Circuit breaker tripped for {mission}/{wp}. {failedCount}/{totalCount} review agents failed after {retryCount} retries. Manual intervention required.",
        "pauseTimeoutMinutes": 60
      },
      "autoResumeWithReducedQuorum": false
    },

    "checkpoint": {
      "enabled": true,
      "directory": ".archon/checkpoints",
      "snapshotBeforeFix": true,
      "maxFixAttempts": 3,
      "retentionDays": 30
    },

    "rollback": {
      "strategy": "git-stash",
      "autoRollbackOnFailure": false
    }
  },

  "ai": {
    "provider": "codex",
    "model": "gpt-5.4-mini",
    "temperature": 0.2,
    "maxTokens": 8192
  },

  "notifications": {
    "onCheckpoint": false,
    "onReviewPass": false,
    "onReviewFail": true,
    "onCircuitBreakerTrip": true,
    "onPhaseComplete": true,
    "onMissionComplete": true
  }
}
