# Archon Spec-Kitty Workflow — Environment Configuration
# Copy this file to .archon/workflow.env and fill in your values.
#
# Usage:
#   source .archon/workflow.env
#   # or
#   set -a && source .archon/workflow.env && set +a

# ── Project Paths ──────────────────────────────────────────────

# Absolute path to your project root (where .archon/ lives)
PROJECT_DIR=/home/lonewolf09/Documents/Projects/ticktick-gemini

# Absolute path to the Archon CLI installation (if not in $PATH)
ARCHON_DIR=/home/lonewolf09/Documents/Projects/Archon

# Workflow log file (default location)
LOG_FILE=/tmp/archon-workflow-run.log

# ── Telegram Notifications ─────────────────────────────────────

# Bot token from @BotFather on Telegram
# Leave empty to disable Telegram notifications (logs are still written to file)
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID. Get it by messaging your bot and visiting:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ── Monitor Settings ──────────────────────────────────────────

# How often the monitor checks progress (seconds)
# Recommended: 180 (3 minutes) for normal runs, 60 for debugging
MONITOR_INTERVAL=180

# Minutes of inactivity before flagging a node as stuck
# If a node runs this long with no commits or file changes, a WARNING is sent
MAX_STUCK_MINUTES=10

# ── Advanced ──────────────────────────────────────────────────

# Log rotation thresholds (used by rotate-archon-logs.sh)
# Logs older than this (days) are deleted during rotation
LOG_RETENTION_DAYS=7

# Maximum log file size before emergency rotation (MB)
LOG_MAX_SIZE_MB=10

# Lines to keep when truncating logs under 5MB
LOG_TRUNCATE_LINES=5000
