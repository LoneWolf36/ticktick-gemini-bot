# TickTick-Gemini Workflow Environment
# Copy to: workflow.env
# Usage:
#   set -a && source workflow.env && set +a

# ============================================================
# Required runtime vars (write pipeline enabled)
# ============================================================

TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_REDIRECT_URI=http://127.0.0.1:8080

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Preferred (multi-key rotation)
GEMINI_API_KEYS=
# Optional fallback if GEMINI_API_KEYS unset
# GEMINI_API_KEY=

# ============================================================
# Pipeline runtime mode
# ============================================================

# polling (local) | webhook (cloud)
BOT_MODE=polling
PORT=8080

# Webhook-only
# WEBHOOK_URL=https://your-app.onrender.com
# TELEGRAM_WEBHOOK_SECRET=

# ============================================================
# Optional behavior + scheduler
# ============================================================

USER_TIMEZONE=Europe/Dublin
DAILY_BRIEFING_HOUR=8
WEEKLY_DIGEST_DAY=0
POLL_INTERVAL_MINUTES=5

# Default project for new tasks (default: Inbox)
# DEFAULT_PROJECT_NAME=Inbox

AUTO_APPLY_LIFE_ADMIN=true
AUTO_APPLY_DROPS=false
AUTO_APPLY_MODE=metadata-only

# ============================================================
# Optional persistence + context
# ============================================================

# REDIS_URL=redis://default:password@host:port
# USER_CONTEXT=<paste content of services/user_context.js>

# Optional OAuth bootstrap tokens (for ephemeral environments)
# TICKTICK_ACCESS_TOKEN=
# TICKTICK_REFRESH_TOKEN=

# ============================================================
# Optional reliability tuning
# ============================================================

# PIPELINE_TRANSIENT_MAX_RETRIES=1
# PIPELINE_TRANSIENT_BASE_DELAY_MS=250
# PIPELINE_TRANSIENT_MAX_DELAY_MS=4000

# TICKTICK_RATE_LIMIT_MAX_RETRIES=3
# TICKTICK_RATE_LIMIT_BASE_DELAY_MS=1000
# TICKTICK_RATE_LIMIT_MAX_DELAY_MS=30000

# BEHAVIORAL_SIGNAL_RETENTION_DAYS=30
# BEHAVIORAL_SIGNAL_ARCHIVE_DAYS=90

# ============================================================
# Optional AI model configuration
# ============================================================

# GEMINI_MODEL_FAST=gemini-2.5-flash
# GEMINI_MODEL_ADVANCED=gemini-2.5-pro

# Gemini model fallback chains (comma-separated, tried in order when primary is rate-limited)
# GEMINI_MODEL_FAST_FALLBACKS=gemini-3-flash-preview,gemini-2.5-flash-lite,gemini-3.1-flash-lite-preview
# GEMINI_MODEL_ADVANCED_FALLBACKS=gemini-3-flash-preview
