#!/bin/sh
echo "Running duplicate code checks..."

# Run JSCPD with higher threshold for pre-commit (catch only major issues)
npx jscpd --threshold 10 --min-lines 10 || {
  echo ""
  echo "⚠️  Significant code duplication detected!"
  echo "   Please refactor the duplicates before committing."
  echo "   See docs/jscpd-baseline.html for details."
  exit 1
}



echo "✅ Duplicate checks passed"
exit 0
